# Configuración de Variables de Entorno para Desarrollo Local

# Clave de API de Gemini (Obtenla en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_clave_aqui

# Configuración de Firebase (Copia estos valores de tu consola de Firebase o de firebase-applet-config.json)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
